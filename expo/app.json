{
  "expo": {
    "name": "Drift",
    "slug": "drift",
    "owner": "brittm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "drift",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.day.drift",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Drift uses your location to help you search for and save places.",
        "NSCalendarsUsageDescription": "Drift reads your calendar to plan your day around your commitments.",
        "NSRemindersUsageDescription": "Drift can add reminders to help you track tasks.",
        "NSUserNotificationsUsageDescription": "Drift sends a morning plan notification so you know what's ahead.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "io.day.drift"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "957ad0a6-ca95-4e2a-a99c-396cfb33412f"
      },
      "router": {}
    }
  }
}
